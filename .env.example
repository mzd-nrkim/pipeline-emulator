# Airflow
# 기본 executor: SequentialExecutor (compose에서 하드코딩, 이 파일의 값은 참고용)
# AIRFLOW__CORE__EXECUTOR=SequentialExecutor
CHUNKING_API_URL=http://mock-api:8000/chunk  # real: https://your-chunking-api.example.com/chunk
ENRICH_API_URL=http://mock-api:8000/enrich  # real: https://your-enrich-api.example.com/enrich

# SeaweedFS S3
SEAWEEDFS_ENDPOINT=http://seaweedfs:8333
SEAWEEDFS_ACCESS_KEY=any
SEAWEEDFS_SECRET_KEY=any

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=pipeline_emulator
MYSQL_USER=emulator
MYSQL_PASSWORD=emulator_pass

# ui-backend / frontend
PUBLIC_UI_BACKEND_URL=http://localhost:8001

# PII
MASK=regex

# CDC (Change Data Capture)
# CDC=on 으로 설정 후 COMPOSE_PROFILES=cdc 환경변수와 함께 기동:
#   COMPOSE_PROFILES=cdc docker compose up
# CDC=off(기본)이면 --profile 없이 docker compose up — CDC 서비스 미기동
CDC=off

# Valkey (Redis 호환 스트림 백엔드)
VALKEY_HOST=valkey
VALKEY_PORT=6379

# Debezium CDC 소스 커넥터
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=debezium_pass
DEBEZIUM_TOPIC_PREFIX=pipeline
# Debezium이 생성하는 Redis Stream 키 패턴: pipeline.<db>.<table>
# 예: pipeline.pipeline_emulator.bronze_document_hub

# CDC 방식 선택 토글 (CDC=on 시 유효)
# 기본값: debezium (binlog 실시간 CDC)
# polling: NiFi QueryDatabaseTableRecord + upd_dts 컬럼 기반 (~30s 지연, DELETE 미감지)
# trigger: NiFi QueryDatabaseTableRecord + AFTER 트리거 change_log 테이블 기반 (I/U/D 전부 감지)
CDC_METHOD=debezium

# ─────────────────────────────────────────
# CeleryExecutor 분산 모드 (F6 — 기본 off)
# 기동 방법:
#   AIRFLOW_EXECUTOR=CeleryExecutor \
#   AIRFLOW_SQL_CONN=mysql+pymysql://emulator:emulator_pass@mysql:3306/pipeline_emulator \
#   CELERY_BROKER_URL=redis://valkey:6379/1 \
#   CELERY_RESULT_BACKEND=db+mysql+pymysql://emulator:emulator_pass@mysql:3306/pipeline_emulator \
#   COMPOSE_PROFILES=celery docker compose up -d
# 복귀: docker compose up -d (프로파일 미지정 = SequentialExecutor+SQLite)
# ─────────────────────────────────────────
AIRFLOW_EXECUTOR=SequentialExecutor
# AIRFLOW_SQL_CONN=mysql+pymysql://emulator:emulator_pass@mysql:3306/pipeline_emulator
# CELERY_BROKER_URL=redis://valkey:6379/1
# CELERY_RESULT_BACKEND=db+mysql+pymysql://emulator:emulator_pass@mysql:3306/pipeline_emulator
